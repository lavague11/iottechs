# Copy to .env.local for local dev, and set these in your host's env-var settings for production.
# NEVER commit real values — .env* is gitignored.

# --- Secrets (generate long random strings for production) ---
# e.g. run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string
PREVIEW_SECRET=change-me-to-another-random-string

# --- Database location ---
# Local dev: leave unset (defaults to ./data). Production: point at your persistent disk mount.
# DB_DIR=/data

# --- Carrier tracking (AfterShip) ---
TRACKING_PROVIDER=aftership
TRACKING_API_KEY=your-aftership-key

# --- Google Maps (restrict this key by HTTP referrer in Google Cloud) ---
GOOGLE_MAPS_API_KEY=your-google-maps-key
